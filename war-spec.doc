War Card Game — Go Spec
Domain Model
Card

Suit — enum: Spades, Clubs, Hearts, Diamonds
Rank — int value 2–14 (J=11, Q=12, K=13, A=14)
Comparison is by Rank only; suit is cosmetic in War
Deck

Holds []Card (52 cards)
NewDeck() builds full ordered deck
Shuffle() randomizes order
Deal() splits into two halves
Player

Name string
Hand — a queue of cards (draw from front, win to back)
HasCards() bool
Game

Two players, round loop, war resolution, winner detection
Project Layout
war/
├── go.mod
├── main.go
└── internal/
    └── game/
        ├── card.go
        ├── deck.go
        ├── player.go
        └── game.go
card.go
go
package game

import "fmt"

type Suit int

const (
	Spades Suit = iota
	Clubs
	Hearts
	Diamonds
)

func (s Suit) String() string {
	return [...]string{"Spades", "Clubs", "Hearts", "Diamonds"}[s]
}

type Card struct {
	Rank int // 2..14
	Suit Suit
}

func (c Card) String() string {
	names := map[int]string{11: "Jack", 12: "Queen", 13: "King", 14: "Ace"}
	if n, ok := names[c.Rank]; ok {
		return fmt.Sprintf("%s of %s", n, c.Suit)
	}
	return fmt.Sprintf("%d of %s", c.Rank, c.Suit)
}
deck.go
go
package game

import (
	"math/rand"
)

type Deck struct {
	Cards []Card
}

func NewDeck() *Deck {
	d := &Deck{}
	for s := Spades; s <= Diamonds; s++ {
		for r := 2; r <= 14; r++ {
			d.Cards = append(d.Cards, Card{Rank: r, Suit: s})
		}
	}
	return d
}

func (d *Deck) Shuffle(rng *rand.Rand) {
	rng.Shuffle(len(d.Cards), func(i, j int) {
		d.Cards[i], d.Cards[j] = d.Cards[j], d.Cards[i]
	})
}

// Deal splits the deck evenly into two slices.
func (d *Deck) Deal() ([]Card, []Card) {
	mid := len(d.Cards) / 2
	return d.Cards[:mid], d.Cards[mid:]
}
player.go
go
package game

type Player struct {
	Name string
	Hand []Card // index 0 = top (draw), append = bottom (win)
}

func (p *Player) HasCards() bool { return len(p.Hand) > 0 }

// Draw removes and returns the top card. Caller must check HasCards first.
func (p *Player) Draw() Card {
	c := p.Hand[0]
	p.Hand = p.Hand[1:]
	return c
}

// Collect adds won cards to the bottom of the hand.
func (p *Player) Collect(cards ...Card) {
	p.Hand = append(p.Hand, cards...)
}
game.go — Core Loop
go
package game

import (
	"fmt"
	"math/rand"
)

type Game struct {
	P1, P2 *Player
	rng    *rand.Rand
}

func New(name1, name2 string, seed int64) *Game {
	deck := NewDeck()
	rng := rand.New(rand.NewSource(seed))
	deck.Shuffle(rng)
	h1, h2 := deck.Deal()
	return &Game{
		P1:  &Player{Name: name1, Hand: h1},
		P2:  &Player{Name: name2, Hand: h2},
		rng: rng,
	}
}
Round logic (the heart of War)
Each round:

Both players draw their top card.
Higher rank takes both cards.
Tie → war: each player puts down 3 face-down cards + 1 face-up. Compare the face-up cards. Repeat on further ties.
If a player can't field enough cards for a war, they lose the game.
go
// playRound returns the cards on the table and the winner (nil = continue, decided elsewhere).
func (g *Game) playRound() (winner *Player, loser *Player, decided bool) {
	pot := []Card{}

	for {
		// Both must have at least one card to face off.
		if !g.P1.HasCards() {
			return g.P2, g.P1, true
		}
		if !g.P2.HasCards() {
			return g.P1, g.P2, true
		}

		c1 := g.P1.Draw()
		c2 := g.P2.Draw()
		pot = append(pot, c1, c2)

		fmt.Printf("%s plays %s | %s plays %s\n", g.P1.Name, c1, g.P2.Name, c2)

		switch {
		case c1.Rank > c2.Rank:
			g.P1.Collect(pot...)
			return nil, nil, false
		case c2.Rank > c1.Rank:
			g.P2.Collect(pot...)
			return nil, nil, false
		default:
			fmt.Println("WAR!")
			// Each lays down up to 3 face-down cards (or as many as they have).
			if w, l, d := g.layWarStakes(&pot); d {
				return w, l, true
			}
			// loop continues: next iteration draws the face-up war cards
		}
	}
}

// layWarStakes moves up to 3 face-down cards from each player into the pot.
// If a player runs out mid-war, the other wins the game.
func (g *Game) layWarStakes(pot *[]Card) (winner, loser *Player, decided bool) {
	for i := 0; i < 3; i++ {
		if !g.P1.HasCards() {
			return g.P2, g.P1, true
		}
		if !g.P2.HasCards() {
			return g.P1, g.P2, true
		}
		*pot = append(*pot, g.P1.Draw(), g.P2.Draw())
	}
	return nil, nil, false
}
Top-level driver
go
func (g *Game) Play(maxRounds int) {
	for round := 1; round <= maxRounds; round++ {
		if !g.P1.HasCards() {
			fmt.Printf("%s wins!\n", g.P2.Name)
			return
		}
		if !g.P2.HasCards() {
			fmt.Printf("%s wins!\n", g.P1.Name)
			return
		}

		winner, _, decided := g.playRound()
		if decided {
			fmt.Printf("%s wins the game!\n", winner.Name)
			return
		}

		fmt.Printf("After round %d: %s=%d, %s=%d\n\n",
			round, g.P1.Name, len(g.P1.Hand), g.P2.Name, len(g.P2.Hand))
	}
	// maxRounds reached: winner by card count (War can loop forever otherwise)
	switch {
	case len(g.P1.Hand) > len(g.P2.Hand):
		fmt.Printf("%s wins on cards!\n", g.P1.Name)
	case len(g.P2.Hand) > len(g.P1.Hand):
		fmt.Printf("%s wins on cards!\n", g.P2.Name)
	default:
		fmt.Println("Draw!")
	}
}
main.go
go
package main

import (
	"time"
	"war/internal/game"
)

func main() {
	g := game.New("Player 1", "Player 2", time.Now().UnixNano())
	g.Play(100000) // cap prevents infinite games
}
Key Design Decisions
Hand as a slice queue — draw from index 0, append winnings to the end. Mirrors real War where won cards go to the bottom. (Swap to container/list or a ring buffer if you want O(1) front-draws at scale; slice reslicing is fine for 52 cards.)
Rank-only comparison — suit exists for display but never decides a round, matching standard War rules.
Seeded RNG injected — deterministic games for tests; pass a fixed seed to reproduce a match exactly.
maxRounds cap — War can loop infinitely; the cap guarantees termination and falls back to a card-count winner.
Pot collection order — winner collects all table cards; some variants shuffle the pot before collecting to avoid deterministic loops. Add rng.Shuffle(pot) before Collect if you want that.
Things to Add Next
A Stats struct tracking war count and longest war, a --verbose flag to silence per-card output, table-driven tests for playRound (especially the war-with-insufficient-cards edge case), and a benchmark to measure average game length across seeds.

